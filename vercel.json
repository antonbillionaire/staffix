{
  "buildCommand": "prisma generate && (prisma migrate resolve --applied 0_init || true) && prisma migrate deploy && next build",
  "installCommand": "npm install",
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "staffix.io" }],
      "destination": "https://www.staffix.io/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/api/telegram/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/broadcasts",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/automations",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/summarize",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/admin-automations",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/refresh-meta-tokens",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/onboarding-drip",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/ai-learning",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/insights-weekly",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/meta-insights",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/ad-insights",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/enrich-catalog",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/paypro-reconciliation",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/subscription-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/partner-earnings-unlock",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/cache-warmer",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/victor-follow-up",
      "schedule": "*/30 * * * *"
    }
  ]
}
