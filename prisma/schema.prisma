generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Пользователи платформы (владельцы бизнесов)
model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  name     String

  // Блокировка (для админских санкций — подозрительная активность,
  // конкурентный probing, спам, нарушение условий). isBlocked=true
  // запрещает логин и заставляет бот молчать для бизнеса юзера.
  isBlocked     Boolean   @default(false)
  blockedReason String?
  blockedAt     DateTime?

  // Верификация email
  emailVerified       Boolean   @default(false)
  verificationToken   String?   @unique
  verificationExpires DateTime?

  // Сброс пароля
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  // Реферальная атрибуция
  referredByCode String? // код партнёра, использованный при регистрации

  // Настройки
  theme String @default("dark") // dark, light

  // Настройки уведомлений
  notifyNewBookings   Boolean @default(true)
  notifyCancellations Boolean @default(true)
  notifyLowMessages   Boolean @default(true)
  notifyTrialEnding   Boolean @default(true)

  // Drip campaign tracking
  lastLoginAt          DateTime?
  onboardingEmailsSent Json      @default("[]") // ["day2_services", "day5_channel", "day14_inactive"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businesses     Business[]
  supportTickets SupportTicket[]
}

// Бизнесы
model Business {
  id             String  @id @default(cuid())
  name           String
  phone          String?
  address        String?
  workingHours   String?
  welcomeMessage String?

  // Onboarding
  businessType         String? // salon, clinic, barbershop, auto_service, other
  businessTypes        String[] @default([]) // массив типов бизнеса (мульти-выбор)
  dashboardMode        String   @default("service") // "service" or "sales" — determines dashboard layout
  // Sales-mode businesses (онлайн-школы, консалтинг, коучи) часто продают
  // через бесплатную консультацию: AI должен уметь и оформить заказ, и
  // записать клиента на встречу. Этот флаг разрешает в sales mode подключать
  // booking-инструменты дополнительно к sales-tools.
  consultationsEnabled Boolean  @default(false)

  // Распределение новых лидов между менеджерами:
  //   manual       — никого не назначаем автоматически (текущее поведение)
  //   round_robin  — по очереди следующему сотруднику с acceptsLeads=true
  //   by_load      — кому меньше открытых задач + клиентов в активных стадиях
  // lastAssignedStaffId хранит указатель для round-robin между запусками.
  leadAssignmentMode  String  @default("manual")
  lastAssignedStaffId String?

  // Кастомные поля карточки клиента — определяются владельцем бизнеса.
  // Формат: [{ key: string, label: string, type: "text"|"number"|"date"|"select", options?: string[] }]
  // Лимит мягкий (валидируется в API): 20 полей. Значения хранятся в Client.customFields.
  clientFieldsConfig  Json    @default("[]")
  staffCount          Int? // количество сотрудников
  language            String  @default("ru") // ru, uz, kz, kg, tj, am, ge
  onboardingCompleted Boolean @default(false)

  // ========================================
  // AI LEARNING - Расширенный профиль бизнеса
  // ========================================

  // Детальная категория (spa, nail_salon, hair_salon, massage, etc.)
  industryCategory String?

  // Город/регион для локальных рекомендаций
  city    String?
  country String? @default("UZ")

  // Часовой пояс бизнеса (IANA формат)
  timezone String @default("Asia/Tashkent")

  // Средний чек (для рекомендаций ценообразования)
  averageCheck Int?

  // Целевая аудитория
  // JSON: { "gender": "female", "ageRange": "25-45", "income": "medium" }
  targetAudience Json?

  // AI-выученные инсайты о бизнесе
  // JSON: { "popularServices": [...], "peakHours": [...], "commonQuestions": [...] }
  aiInsights Json?

  // Статистика для обучения
  totalConversations Int    @default(0)
  totalBookings      Int    @default(0)
  conversionRate     Float? // % разговоров → записи

  // CRM интеграция (вопрос при онбординге)
  crmSystem String? // none, bitrix24, amocrm, smartup, billz, 1c, other

  // AI настройки
  aiTone         String? // friendly, professional, casual
  aiRules        String? // что можно/нельзя говорить
  systemPrompt   String? // сгенерированный промпт для AI
  botDisplayName String? // Имя бота для клиентов (напр. "Алия", "Виктор")

  // Telegram bot
  botToken      String? @unique
  botUsername   String?
  botActive     Boolean @default(false)
  webhookSecret String? // HMAC secret для верификации Telegram webhook (secret_token)

  // Telegram уведомления владельца
  ownerTelegramUsername String? // @username владельца для уведомлений
  ownerTelegramChatId   BigInt? // автоматически при /start

  // Доставка
  deliveryEnabled  Boolean @default(false)
  deliveryTimeFrom Int? // минуты (от)
  deliveryTimeTo   Int? // минуты (до)
  deliveryFee      Int? // стоимость доставки
  deliveryFreeFrom Int? // бесплатная доставка от суммы
  deliveryZones    String? // текстовое описание зон

  // Платёжные системы (для магазинов)
  paymeId         String? // Payme Merchant ID
  clickServiceId  String? // Click Service ID
  clickMerchantId String? // Click Merchant ID

  // WhatsApp Business API (прямое подключение от Meta)
  waPhoneNumberId    String?   // Meta Phone Number ID
  waAccessToken      String?   // Meta User/System Access Token
  waTokenExpiresAt   DateTime? // Когда истекает waAccessToken (~60 дней). Refresh cron продлевает.
  waVerifyToken      String?   // Random secret для верификации webhook
  waActive           Boolean   @default(false)

  // Facebook Messenger (прямое подключение страницы)
  fbPageId          String? // Facebook Page ID
  fbPageAccessToken String? // Page Access Token
  fbVerifyToken     String? // Random secret для верификации webhook
  fbActive          Boolean @default(false)

  // Instagram (via connected Facebook Page)
  igBusinessAccountId String? // Instagram Business Account ID
  igUsername          String? // @username для отображения
  igActive            Boolean @default(false)

  // Meta OAuth (shared for FB + IG, managed by Facebook Login flow)
  metaUserId          String? // Facebook/Meta User ID (for data deletion scoping)
  metaUserAccessToken String? // Long-lived User Access Token (60 дней)
  metaTokenExpiresAt  DateTime? // Когда истекает

  // Sprint 4D (M18) — Meta Ad Insights для владельца.
  // Ad Account ID из Meta Ads Manager (act_XXXXXXXXX). Владелец вводит
  // руками в настройках; без него /dashboard/ads показывает empty state.
  fbAdAccountId String?

  // Claude API usage tracking
  tokensUsedInput  Int @default(0) // input tokens consumed
  tokensUsedOutput Int @default(0) // output tokens consumed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  services      Service[]
  staff         Staff[]
  faqs          FAQ[]
  bookings      Booking[]
  conversations Conversation[]
  subscription  Subscription?
  documents     Document[]

  // Автоматизации
  automationSettings AutomationSettings?
  scheduledReminders ScheduledReminder[]
  reviews            Review[]
  clients            Client[]

  // Уведомления
  notifications Notification[]

  // Рассылки клиентам
  clientBroadcasts ClientBroadcast[]

  // Мультиканальность (WhatsApp, Instagram)
  channelConnections ChannelConnection[]
  channelClients     ChannelClient[]

  // Telegram Business — бот в личных чатах владельца и/или сотрудников.
  // Опционально: каждый (владелец + любой сотрудник с /start) сам подключает
  // через TG Settings → Business → Chatbots. Один бизнес — несколько подключений
  // (по одному на каждого подключившегося человека).
  tgBusinessConnections TelegramBusinessConnection[]

  // CRM интеграции
  crmIntegrations CrmIntegration[]

  // Журнал активности бота (см. BusinessActivityLog)
  activityLogs BusinessActivityLog[]

  // Задачи менеджеров
  tasks Task[]

  servicePackages          ServicePackage[]
  serviceIncompatibilities ServiceIncompatibility[]

  // WhatsApp/Facebook разговоры
  channelConversations ChannelConversation[]

  // Channel messages and leads
  channelMessages ChannelMessage[]
  leads           Lead[]

  // AI Learning
  botCorrections   BotCorrection[]
  aiInsightRecords AiInsight[]
  metaInsights     MetaInsight[]   @relation("MetaInsightBusiness")
  adInsights       AdCampaignInsight[] @relation("AdInsightBusiness")

  // Программы лояльности (может быть несколько типов)
  loyaltyPrograms LoyaltyProgram[]

  // Продажи (магазины, e-commerce)
  products Product[]
  orders   Order[]

  // Зоны доставки
  deliveryZonesRel DeliveryZone[]

  @@index([fbPageId])
  @@index([igBusinessAccountId])
  @@index([waPhoneNumberId])
}

// Зоны доставки
model DeliveryZone {
  id        String  @id @default(cuid())
  name      String // "Центр", "Окраины", "Экспресс"
  fee       Int // стоимость доставки
  currency  String  @default("UZS") // UZS, KZT, RUB, KGS, USD
  timeFrom  Int? // мин. время в минутах
  timeTo    Int? // макс. время в минутах
  freeFrom  Int? // бесплатно от суммы
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, isActive])
}

// Услуги
model Service {
  id          String  @id @default(cuid())
  name        String
  description String? // описание услуги
  price       Int
  duration    Int // минуты

  // Автодобавление: при выборе этой услуги автоматически предложить эти услуги
  // Хранится массив ID услуг через запятую (для простоты)
  autoAddServiceIds String[] @default([])

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  bookings           Booking[]
  packageItems       ServicePackageItem[]
  incompatibilitiesA ServiceIncompatibility[] @relation("ServiceA")
  incompatibilitiesB ServiceIncompatibility[] @relation("ServiceB")

  @@index([businessId])
}

// Пакет услуг (комбо со скидкой или фикс. ценой)
model ServicePackage {
  id String @id @default(cuid())

  name        String // "Свадебный комплекс", "Стрижка + борода"
  description String?

  // Тип скидки: percent (процент) | fixed (фикс. цена за весь пакет) | none (без скидки)
  discountType    String @default("percent")
  discountPercent Float? // если discountType = "percent"
  fixedPrice      Int? // если discountType = "fixed" — общая цена пакета

  isActive Boolean @default(true)

  // AI должен ли предлагать клиентам этот пакет автоматически
  autoSuggest Boolean @default(true)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  items    ServicePackageItem[]
  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, isActive])
}

// Услуги внутри пакета
model ServicePackageItem {
  id String @id @default(cuid())

  packageId String
  package   ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Порядок в пакете (для UI)
  sortOrder Int @default(0)

  @@unique([packageId, serviceId])
  @@index([packageId])
}

// Несовместимости услуг
// "После услуги A нельзя делать услугу B в течение N дней"
model ServiceIncompatibility {
  id String @id @default(cuid())

  // Первая услуга (которая делается)
  serviceAId String
  serviceA   Service @relation("ServiceA", fields: [serviceAId], references: [id], onDelete: Cascade)

  // Несовместимая услуга (one of serviceBId / serviceBText must be set)
  serviceBId String?
  serviceB   Service? @relation("ServiceB", fields: [serviceBId], references: [id], onDelete: Cascade)

  // Внешнее ограничение свободным текстом (солнце, баня, алкоголь и т.п.)
  serviceBText String?

  // Период несовместимости в днях после серии A
  cooldownDays Int @default(7)

  // Симметрично? (если да — то и B->A нельзя)
  bidirectional Boolean @default(true)

  // Причина для бота (объясняет клиенту)
  reason String? // "Не рекомендуется делать массаж лица в течение 5 дней после ботокса"

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([businessId])
  @@index([serviceAId])
  @@index([serviceBId])
}

// Мастера/сотрудники
model Staff {
  id             String  @id @default(cuid())
  name           String
  role           String? // канонизированное значение из dropdown: admin, manager, master, doctor, operator, custom
  specialization String? // свободный текст ("Барбер-стилист", "Терапевт") — только для отображения, фильтры идут по role
  photo          String? // base64 data URL или URL к фото

  // Telegram уведомления
  telegramUsername     String? // @elena_master (владелец заполняет в дашборде)
  telegramChatId       BigInt? // автоматически сохраняется когда мастер пишет /start боту
  notificationsEnabled Boolean @default(true)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Зарплата
  baseRate          Int? // Фиксированная ставка (за месяц)
  commissionPercent Float? // % с услуги/продажи (например 30%)

  // Включён ли в авто-распределение лидов (round-robin / by-load / ai_smart).
  // Default true — новые сотрудники сразу попадают в ротацию. Владелец
  // может выключить если сотрудник в отпуске / на стажировке / не работает с клиентами.
  acceptsLeads Boolean @default(true)

  // Описание специализации для AI-роутинга (режим Business.leadAssignmentMode = "ai_smart").
  // Владелец пишет 1-3 предложения как живому коллеге: «принимаю иностранных
  // туристов, помогаю с визой...». AI читает все routingDescription'ы команды
  // и направляет клиента в зависимости от контекста разговора.
  // Если null или пусто — staff не участвует в AI-роутинге, но остальные функции
  // (записи, заказы, обычные уведомления) работают как раньше.
  routingDescription String? @db.Text

  bookings            Booking[]
  orders              Order[]
  schedule            StaffSchedule[]
  timeOffs            StaffTimeOff[]
  // Задачи назначенные на сотрудника (Task.assignedStaffId → SetNull при удалении)
  assignedTasks       Task[]               @relation("TaskAssignedStaff")

  // Подключения бота к личному Telegram сотрудника (Telegram Business).
  // У одного сотрудника максимум одно активное подключение — TG всё равно
  // не позволит несколько ботов одному аккаунту в Business режиме.
  tgBusinessConnections TelegramBusinessConnection[]

  @@index([businessId])
}

// FAQ / База знаний
model FAQ {
  id       String @id @default(cuid())
  question String
  answer   String

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

// Записи клиентов
model Booking {
  id               String  @id @default(cuid())
  clientName       String
  clientPhone      String?
  clientTelegramId BigInt?

  date   DateTime
  status String   @default("pending") // pending, confirmed, cancelled, completed

  // Флаги напоминаний
  reminder24hSent Boolean @default(false)
  reminder2hSent  Boolean @default(false)
  reviewRequested Boolean @default(false)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  staffId String?
  staff   Staff?  @relation(fields: [staffId], references: [id], onDelete: SetNull)

  // Пакет услуг (если запись часть пакета)
  servicePackageId String?
  servicePackage   ServicePackage? @relation(fields: [servicePackageId], references: [id], onDelete: SetNull)
  packageGroupId   String? // общий ID для всех записей одного пакета (для группировки)

  // Автоматизации
  reminders ScheduledReminder[]
  reviews   Review[]

  createdAt DateTime @default(now())

  @@index([businessId])
  @@index([businessId, date])
  @@index([staffId, date])
  @@index([businessId, clientTelegramId, date])
  @@index([packageGroupId])
}

// Диалоги с клиентами
model Conversation {
  id               String  @id @default(cuid())
  clientTelegramId BigInt
  clientName       String?

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  messages Message[]

  // ========================================
  // AI MEMORY - Фаза 1
  // ========================================

  // AI-сгенерированное краткое содержание разговора
  // Пример: "Клиент записался на массаж на 15 февраля, спрашивал про скидки"
  summary String? @db.Text

  // Тема/цель разговора
  // booking, inquiry, complaint, feedback, other
  topic String?

  // Результат разговора
  // booked, answered, escalated, unresolved
  outcome String?

  // Извлечённая важная информация
  // JSON: { "bookedService": "массаж", "appointmentDate": "2025-02-15", "mentionedIssues": [] }
  extractedInfo Json?

  // Количество сообщений (для триггера summarization)
  messageCount Int @default(0)

  // Флаг: нужно ли обновить summary
  needsSummary Boolean @default(false)

  // Флаг: база знаний (FAQ/документы/услуги/товары) изменилась — обрезать историю
  // в следующем ответе бота, чтобы новые данные имели приоритет над старыми ответами
  needsContextRefresh Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, clientTelegramId])
  @@index([businessId, updatedAt])
  @@index([needsSummary])
}

// Сообщения в диалогах
model Message {
  id      String @id @default(cuid())
  role    String // user, assistant
  content String

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId])
}

// Подписки
model Subscription {
  id            String   @id @default(cuid())
  plan          String   @default("trial") // trial, starter, pro, business, enterprise
  messagesUsed  Int      @default(0)
  messagesLimit Int      @default(100)
  expiresAt     DateTime

  // PayPro Global
  payproOrderId        String? // PayPro ORDER_ID
  payproSubscriptionId String? // PayPro SUBSCRIPTION_ID
  payproCustomerId     String? // PayPro CUSTOMER_ID
  status               String  @default("active") // active, cancelled, suspended, expired
  billingPeriod        String? // monthly, yearly

  // Expiry reminder tracking
  reminder7dSent Boolean @default(false)
  reminder3dSent Boolean @default(false)
  reminder1dSent Boolean @default(false)

  // Message limit warning (sent once at 80%)
  limitWarning80Sent Boolean @default(false)

  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plan, expiresAt])
  @@index([status, expiresAt])
}

// Загруженные документы
model Document {
  id       String @id @default(cuid())
  name     String // имя файла
  type     String // price_list, services, faq, other
  url      String // URL к файлу
  mimeType String // application/pdf, etc.
  size     Int // размер в байтах

  // Извлечённые данные
  extractedText String? // текст из документа
  parsed        Boolean @default(false) // был ли распарсен AI

  // Описание для lazy loading (июль 2026, cost-optimization).
  // description — от владельца, короткий текст «о чём этот файл» для AI-матчера.
  // Владелец пишет ~50-150 символов: «Программы туров, цены на лето 2026»,
  // «Правила отмены и возврата», «Список отелей в Батуми». По этой строке AI
  // решает при каждом запросе клиента: грузить этот документ в промпт или нет.
  //
  // autoDescription — сгенерирован нами через Haiku 4.5 автоматически после
  // загрузки документа, если владелец не заполнил description. Fallback.
  //
  // Если оба пустые — документ считается «недоописанным» и попадает в fallback
  // (грузим на всякий случай, чтобы бот не потерял информацию).
  description     String? @db.Text
  autoDescription String? @db.Text

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// Тикеты поддержки
model SupportTicket {
  id       String @id @default(cuid())
  subject  String
  priority String @default("normal") // low, normal, high
  status   String @default("open") // open, in_progress, resolved, closed
  rating   Int? // 1-5 satisfaction rating

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  messages SupportMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Сообщения в тикетах поддержки
model SupportMessage {
  id            String    @id @default(cuid())
  content       String
  isFromSupport Boolean   @default(false) // true = от поддержки, false = от пользователя
  isRead        Boolean   @default(false) // прочитано ли пользователем
  readAt        DateTime? // когда прочитано

  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// Диалоги пользователей с support-ботом @staffix_support_bot. Раньше история
// хранилась в Map в памяти процесса — на холодных стартах Vercel она терялась
// и бот забывал контекст. Теперь сохраняем в БД, чтобы:
//   1. Бот помнил всё между перезапусками контейнеров
//   2. Можно было смотреть лог обращений (для аудита и обучения промптов)
model SupportBotConversation {
  id String @id @default(cuid())

  // Telegram chat id пользователя — natural key
  telegramChatId BigInt  @unique
  telegramUserId BigInt?
  username       String? // @username если есть
  firstName      String?
  lastName       String?
  language       String? // ru / en / uz / kz — язык первого сообщения

  // Связан ли с зарегистрированным пользователем Staffix (если он залогинен)
  userId String?

  messages SupportBotMessage[]

  // Последняя активность для UI и cleanup'а старых диалогов
  lastMessageAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lastMessageAt])
  @@index([userId])
}

model SupportBotMessage {
  id      String @id @default(cuid())
  role    String // "user" | "assistant"
  content String @db.Text

  conversationId String
  conversation   SupportBotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
}

// ========================================
// АВТОМАТИЗАЦИИ
// ========================================

// Настройки автоматизаций для бизнеса
model AutomationSettings {
  id String @id @default(cuid())

  // Напоминания о записи
  reminder24hEnabled Boolean @default(true)
  reminder2hEnabled  Boolean @default(true)

  // Сбор отзывов
  reviewEnabled    Boolean @default(true)
  reviewDelayHours Int     @default(2) // через сколько часов после визита
  reviewGoogleLink String? // ссылка на Google отзывы
  review2gisLink   String? // ссылка на 2GIS отзывы
  reviewYandexLink String? // ссылка на Яндекс.Карты отзывы

  // Реактивация клиентов
  reactivationEnabled  Boolean @default(true)
  reactivationDays     Int     @default(30) // через сколько дней без визита
  reactivationDiscount Int     @default(10) // размер скидки %

  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Запланированные напоминания
model ScheduledReminder {
  id String @id @default(cuid())

  type   String // reminder_24h, reminder_2h, review, reactivation
  status String @default("pending") // pending, sent, failed, cancelled

  scheduledFor DateTime // когда отправить
  sentAt       DateTime? // когда отправлено

  // Данные для отправки
  clientTelegramId BigInt
  clientName       String?
  serviceName      String?
  appointmentDate  DateTime?

  // Для реактивации
  lastVisitDate DateTime?
  discountCode  String?

  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([status, scheduledFor])
  @@index([businessId, type])
}

// Отзывы клиентов
model Review {
  id String @id @default(cuid())

  rating  Int // 1-5
  comment String?

  clientTelegramId BigInt
  clientName       String?

  // Связь с записью
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id])

  // Статус
  isPublic     Boolean @default(false) // опубликован ли
  responded    Boolean @default(false) // ответил ли бизнес
  responseText String? // ответ бизнеса

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([businessId, rating])
}

// Клиенты (для отслеживания последнего визита)
model Client {
  id String @id @default(cuid())

  // Каналы идентичности клиента (Sprint 3, июль 2026):
  //   telegramId  — was required-only column; теперь nullable, чтобы
  //                 WA/IG/FB-only клиенты жили в этой же таблице.
  //   whatsappId  — Meta WA-ID (обычно = phone без +).
  //   instagramId — Instagram scoped user ID (IGSID).
  //   fbPsid      — Facebook Messenger Page-Scoped ID.
  // Каждый может быть null. Composite unique(businessId, X) на каждом.
  // PostgreSQL по умолчанию NULLS DISTINCT — много rows с NULL не конфликтуют.
  telegramId       BigInt?
  telegramUsername String? // @username из Telegram (без @), обновляется при каждом сообщении
  whatsappId       String?
  instagramId      String?
  fbPsid           String?
  name             String?
  surname          String?
  phone            String?
  email            String?
  company          String? // название бизнеса клиента

  // Лояльность: какие программы назначены (пустой = все)
  loyaltyProgramIds String[] @default([])

  // Статус
  lastVisitDate DateTime?
  totalVisits   Int       @default(0)
  // isBlocked семантически = «отписался от рассылок» — не влияет на бот.
  // Отдельный флаг botMuted (июль 2026) = бот больше не отвечает клиенту
  // ни в одном канале. Разделили после аудита M19: раньше кнопка
  // «Заблокировать» в UI обещала оба эффекта но реально работала только
  // как отписка от рассылок.
  isBlocked     Boolean   @default(false) // отписался от рассылок
  botMuted      Boolean   @default(false) // бот не отвечает этому клиенту

  // Последняя реактивация
  lastReactivationSent DateTime?

  // Лояльность
  loyaltyPoints          Int     @default(0) // бонусные баллы
  loyaltyVisits          Int     @default(0) // кол-во визитов для программы
  loyaltyTotalSpent      Int     @default(0) // общая сумма покупок
  loyaltyCashbackPercent Float? // индивидуальный % кэшбека (null = по программе)
  loyaltyTier            String? // уровень: bronze, silver, gold, platinum (null = авто по программе)

  // ========================================
  // AI MEMORY - Фаза 1
  // ========================================

  // AI-сгенерированное краткое описание клиента
  // Пример: "Постоянный клиент, предпочитает тайский массаж, приходит раз в 2 недели"
  aiSummary String? @db.Text

  // Предпочтения клиента (извлечённые AI из разговоров)
  // JSON: { "preferredServices": ["тайский массаж"], "preferredTime": "утро", "allergies": ["орехи"] }
  preferences Json?

  // Важные заметки (добавленные вручную или AI)
  // Пример: "VIP клиент, всегда давать скидку 10%"
  importantNotes String? @db.Text

  // Настроение/тон общения с этим клиентом
  // formal, friendly, casual
  communicationStyle String?

  // Теги для быстрой категоризации
  // ["vip", "новенький", "проблемный"]
  tags String[] @default([])

  // Статистика общения
  totalMessages Int       @default(0)
  lastMessageAt DateTime?

  // Когда последний раз обновлялся AI summary
  summaryUpdatedAt DateTime?

  // Привязка к продавцу (через ссылку t.me/bot?start=s_staffId)
  assignedStaffId String?

  // Кастомные поля клиента — словарь { [key]: value } по схеме из Business.clientFieldsConfig.
  // Если бизнес удалит определение поля, данные тут не пропадают — просто перестают
  // отображаться в UI. Можно вернуть, восстановив определение.
  customFields Json @default("{}")

  // Email-маркетинг: клиент жмёт "отписаться" в письме → ставится true.
  // isBlocked продолжает блокировать ВСЕ каналы, а это поле — только email-рассылки.
  marketingUnsubscribed Boolean @default(false)
  unsubscribeToken      String? @unique // токен для unsubscribe-ссылки

  // ========================================
  // DEAL PIPELINE (для всех бизнесов)
  // ========================================
  // dealStage: lead | consultation_booked | consultation_done | client | lost
  // По умолчанию все новые клиенты — "lead". Менеджер двигает руками
  // (или AI поднимает stage когда видит что клиент записался / купил).
  dealStage    String    @default("lead")
  dealValue    Int? // сумма сделки в условных единицах (рублях/долларах — что бизнес выбрал)
  dealClosedAt DateTime? // когда клиент стал client или lost
  dealNote     String? // короткая заметка менеджера про сделку

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Задачи привязанные к клиенту (Task.clientId → SetNull при удалении клиента)
  tasks Task[] @relation("TaskClient")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, telegramId])
  @@unique([businessId, whatsappId])
  @@unique([businessId, instagramId])
  @@unique([businessId, fbPsid])
  @@index([businessId, lastVisitDate])
  @@index([businessId, lastMessageAt])
  @@index([businessId, dealStage])
}

// ========================================
// TASKS — задачи для менеджеров (ручные + авто-создаваемые AI)
// ========================================
// Главная боль малого бизнеса по фидбэку amoCRM: менеджеры теряют лидов
// потому что забывают перезвонить. Этот стол — "мои задачи на сегодня"
// в дашборде. AI создаёт задачу когда передаёт диалог человеку (notify_manager),
// менеджер может создать руками для любого клиента.
model Task {
  id String @id @default(cuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Кому назначена. null = "любой свободный менеджер".
  assignedStaffId String?
  assignedStaff   Staff?  @relation("TaskAssignedStaff", fields: [assignedStaffId], references: [id], onDelete: SetNull)

  // С каким клиентом связана (опционально — общая задача без клиента тоже бывает).
  clientId String?
  client   Client? @relation("TaskClient", fields: [clientId], references: [id], onDelete: SetNull)

  // Для эскалаций от бота (июль 2026) — сохраняем канал и ID клиента в канале,
  // чтобы из задачи можно было построить прямую ссылку на переписку в дашборде.
  // Nullable — ручные задачи и старые задачи их не имеют.
  //   clientChannel:   telegram | whatsapp | instagram | facebook
  //   clientChannelId: TG username/chatId, IG scoped ID, WA phone, FB PSID
  clientChannel   String?
  clientChannelId String?

  title       String // "Перезвонить Ивану", "Подготовить КП"
  description String? @db.Text

  // Когда нужно сделать. null = когда успеется (без дедлайна).
  dueAt DateTime?

  // low | normal | high. Срочные эскалации от AI = high.
  priority String @default("normal")

  // pending | done | cancelled
  status String @default("pending")

  // Кто создал. user.id для ручных, "ai" для авто-созданных.
  createdBy String?

  completedAt DateTime?
  completedBy String? // userId кто закрыл

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, status, dueAt])
  @@index([businessId, assignedStaffId, status])
  @@index([clientId])
}

// ========================================
// ADMIN CRM - АВТОМАТИЗАЦИИ И РАССЫЛКИ
// ========================================

// Автоматизации для админа (триггеры + действия)
model AdminAutomation {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Триггер
  trigger       String // trial_expiring, trial_expired, messages_low, etc.
  triggerParams Json   @default("{}")

  // Действие
  action       String // send_email, send_telegram, extend_trial, etc.
  actionParams Json   @default("{}")

  isActive Boolean @default(true)

  executions AutomationExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Логи выполнения автоматизаций
model AutomationExecution {
  id String @id @default(cuid())

  automationId String
  automation   AdminAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  // Для кого сработало
  userId    String?
  userEmail String?

  // Результат
  success Boolean
  error   String?
  details Json    @default("{}")

  createdAt DateTime @default(now())

  @@index([automationId, createdAt])
}

// Рассылки от админа
model Broadcast {
  id   String @id @default(cuid())
  name String

  // Контент
  subject String? // для email
  content String // текст сообщения

  // Канал
  channel String // email, telegram, in_app

  // Фильтры получателей
  targetPlan   String? // all, trial, pro, business
  targetStatus String? // all, active, expired, expiring

  // Статус
  status       String    @default("draft") // draft, scheduled, sending, sent, cancelled
  scheduledFor DateTime?
  sentAt       DateTime?

  // Статистика
  totalRecipients Int @default(0)
  delivered       Int @default(0)
  opened          Int @default(0)
  clicked         Int @default(0)

  deliveries BroadcastDelivery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Доставка рассылки
model BroadcastDelivery {
  id String @id @default(cuid())

  broadcastId String
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  // Получатель
  userId    String
  userEmail String

  // Статус
  status    String    @default("pending") // pending, sent, delivered, opened, clicked, failed
  sentAt    DateTime?
  openedAt  DateTime?
  clickedAt DateTime?
  error     String?

  createdAt DateTime @default(now())

  @@index([broadcastId, status])
  @@index([userId])
}

// Теги пользователей для сегментации
model UserTag {
  id     String @id @default(cuid())
  userId String
  tag    String

  createdAt DateTime @default(now())

  @@unique([userId, tag])
  @@index([tag])
}

// ========================================
// MULTI-CHANNEL MESSAGING (WhatsApp, Instagram)
// ========================================

// Подключение каналов (WhatsApp, Instagram, Telegram)
model ChannelConnection {
  id String @id @default(cuid())

  channel     String // telegram, whatsapp, instagram
  isConnected Boolean @default(false)
  isVerified  Boolean @default(false)

  // Telegram
  telegramBotId       String?
  telegramBotUsername String?

  // WhatsApp Business API
  whatsappPhoneId       String? // Phone Number ID from Meta
  whatsappPhoneNumber   String? // Display phone number
  whatsappBusinessAccId String? // WhatsApp Business Account ID

  // Instagram
  instagramAccountId String? // Instagram Account ID
  instagramUsername  String?
  instagramPageId    String? // Connected Facebook Page ID

  // Meta API credentials (shared for WhatsApp & Instagram)
  metaAccessToken    String? // Access token
  metaTokenExpiresAt DateTime?

  // Webhook
  webhookUrl      String?
  webhookSecret   String?
  webhookVerified Boolean @default(false)

  // Status
  errorMessage String?
  errorAt      DateTime?

  connectedAt    DateTime?
  lastActivityAt DateTime?

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, channel])
  @@index([channel, isConnected])
}

// Telegram Business API connection — бот подключен к личным чатам владельца.
// Документация: https://core.telegram.org/bots/api#businessconnection
//
// Жизненный цикл:
//   1. Владелец в TG → Settings → Telegram Business → Chatbots добавляет @нашего-бота
//   2. Нам прилетает Update.business_connection с id, user_chat_id, can_reply, is_enabled
//   3. Мы upsert'им запись по connectionId, привязываем к Business через ownerUserId
//   4. На каждый Update.business_message от клиента в личном чате владельца —
//      пропускаем через AI и шлём ответ обратно с этим connectionId
//   5. Если is_enabled=false (владелец отключил) — игнорируем входящие
//
// Требование Telegram: у владельца нужен Telegram Premium для самой возможности
// подключить бота (фича Telegram Business). На нашей стороне это никак не
// гейтится — TG просто не отдаст update если у владельца нет Premium.
model TelegramBusinessConnection {
  id String @id @default(cuid())

  // BusinessConnection.id из Telegram — стабильный идентификатор подключения.
  // Используется как business_connection_id в исходящих sendMessage.
  connectionId String @unique

  // Owner identity (Telegram user id владельца, у кого работает бот в личных чатах).
  // Привязка к нашему Business — через этот же id, который должен совпадать с
  // Business.ownerTelegramChatId (тот, кто запустил /start в @нашем-боте раньше).
  ownerUserId BigInt

  // Личный chat_id владельца — нужен чтобы слать ему системные нотификации
  // ("AI подключился к личным чатам", "Клиент Х написал, я обработал").
  ownerChatId BigInt

  // Из BusinessConnection: можем ли отвечать (может быть false если владелец
  // снял право в настройках подключения).
  canReply Boolean @default(false)

  // Из BusinessConnection: подключение активно или владелец поставил на паузу
  // через TG-настройки.
  isEnabled Boolean @default(true)

  // Наш собственный мастер-выключатель из дашборда (быстро отключить без
  // похода в TG-настройки).
  pausedByOwner Boolean @default(false)

  // Когда впервые подключилось и когда последнее изменение пришло
  connectedAt DateTime  @default(now())
  lastEventAt DateTime?

  // Привязка к бизнесу — теперь МОЖНО несколько подключений на один бизнес,
  // потому что владелец И сотрудники могут каждый подключить бота к своему
  // личному Telegram. См. staffId ниже — различает владельца от сотрудника.
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Если null — это подключение владельца (совпадение с Business.ownerTelegramChatId).
  // Если задан — конкретный сотрудник подключил бота в свой TG (совпадение с
  // Staff.telegramChatId). Нужно чтобы владелец в дашборде понимал кто и где.
  staffId String?
  staff   Staff?  @relation(fields: [staffId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, ownerUserId]) // один человек не может подключить дважды
  @@index([connectionId])
  @@index([ownerUserId])
  @@index([staffId])
}

// Клиенты со всех каналов (унифицированные)
model ChannelClient {
  id String @id @default(cuid())

  // Имя
  name      String?
  firstName String?
  lastName  String?

  // Telegram
  telegramId       String?
  telegramUsername String?
  telegramChatId   String?

  // WhatsApp
  whatsappPhone String?
  whatsappId    String?

  // Instagram
  instagramId       String?
  instagramUsername String?

  // Facebook Messenger (PSID — Page-Scoped ID, длинная строка от Meta).
  // Раньше Facebook PSID ошибочно сохранялся в поле instagramId — это ломало
  // идентификацию когда у бизнеса есть и FB и IG клиенты. Новый код пишет PSID
  // сюда, старые записи находятся через fallback на instagramId в channel-memory.ts.
  fbPsid String?

  // Контактные данные
  email String?
  phone String?

  // Профиль
  profilePicUrl String?
  language      String?
  timezone      String?

  // Вовлечённость
  firstContactAt DateTime @default(now())
  lastContactAt  DateTime @default(now())
  lastChannel    String? // telegram, whatsapp, instagram
  totalMessages  Int      @default(0)

  // Кастомизация
  tags         String[] @default([])
  notes        String?
  customFields Json?

  // AI Memory — профиль клиента
  aiSummary          String?   @db.Text // AI-generated: "Постоянный клиент, предпочитает массаж, приходит каждые 2 недели"
  preferences        Json? // { preferredServices: [...], preferredTime: "morning", allergies: [...] }
  importantNotes     String?   @db.Text // "VIP", "аллергия на аммиак", "всегда опаздывает на 10 мин"
  communicationStyle String? // formal, friendly, casual (auto-detected)
  totalVisits        Int       @default(0)
  lastVisitDate      DateTime?
  summaryUpdatedAt   DateTime?

  // M19: бот больше не отвечает этому клиенту (owner-driven mute).
  // Аналог Client.botMuted для канальных клиентов, у которых нет TG-идентичности.
  botMuted           Boolean   @default(false)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Связи
  messages ChannelMessage[]
  leads    Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, telegramId])
  @@index([businessId, whatsappPhone])
  @@index([businessId, instagramId])
  @@index([businessId, lastContactAt])
}

// Сообщения из всех каналов
model ChannelMessage {
  id String @id @default(cuid())

  channel          String // telegram, whatsapp, instagram
  channelMessageId String? // ID сообщения в канале
  chatId           String // ID чата в канале

  direction String // incoming, outgoing
  status    String @default("sent") // pending, sent, delivered, read, failed

  // Контент
  text        String?
  attachments Json? // [{type, url, ...}]

  // AI обработка
  aiProcessed Boolean @default(false)
  aiResponse  String?

  // Статусы доставки
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?

  // Ошибки
  errorMessage String?
  errorCode    String?

  // Метаданные
  metadata Json?

  clientId String?
  client   ChannelClient? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([businessId, channel])
  @@index([businessId, clientId])
  @@index([businessId, createdAt])
  @@index([chatId, channel])
}

// Лиды (из рекламы Instagram/WhatsApp)
model Lead {
  id String @id @default(cuid())

  source  String // instagram_ad, whatsapp_ctwa, organic, referral, channel_message
  adId    String? // ID рекламы
  channel String // telegram, whatsapp, instagram, messenger

  clientName   String? // Имя клиента
  firstMessage String? // Первое сообщение клиента
  status       String  @default("cold") // cold, warm, hot, client

  // Оценка
  score       Int       @default(0) // 0-100
  qualifiedAt DateTime? // когда стал hot или client
  convertedAt DateTime?

  // Взаимодействие
  lastInteractionAt DateTime? // последнее сообщение
  statusReason      String? // почему изменён статус

  // Метаданные
  metadata Json?
  notes    String?

  clientId String?
  client   ChannelClient? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, channel, clientId])
  @@index([businessId, source])
  @@index([businessId, status])
  @@index([businessId, createdAt])
}

// ========================================
// CLIENT CRM - РАССЫЛКИ ДЛЯ КЛИЕНТОВ БИЗНЕСА
// ========================================

// Рассылки от бизнеса своим клиентам
model ClientBroadcast {
  id String @id @default(cuid())

  title   String // название рассылки
  content String // текст сообщения

  // Сегментация
  targetSegment String @default("all") // all, vip, active, inactive

  // Канал доставки: telegram | email | both. Default telegram —
  // обратная совместимость со старыми рассылками.
  channel String @default("telegram")

  // Статус
  status      String    @default("draft") // draft, scheduled, sending, sent, cancelled
  scheduledAt DateTime?
  sentAt      DateTime?

  // Статистика
  recipientsCount Int @default(0)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  deliveries ClientBroadcastDelivery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, status])
}

// Доставка рассылки клиенту
model ClientBroadcastDelivery {
  id String @id @default(cuid())

  broadcastId String
  broadcast   ClientBroadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  // Получатель
  clientId   String
  // telegramId nullable, чтобы email-доставки для WA/IG/FB-only клиентов
  // не требовали фиктивного telegramId=0. Sprint 3, июль 2026.
  telegramId BigInt?
  // Email — заполняется только для email-доставок. Snapshot на момент рассылки
  // (если клиент потом сменит email, в логе остаётся куда реально ушло).
  email      String?
  // Конкретный канал именно этой доставки (telegram | email). Нужен когда
  // у broadcast.channel = "both" — каждой подписке свой канал.
  channel    String  @default("telegram")

  // Статус
  status String    @default("pending") // pending, sent, delivered, failed
  sentAt DateTime?
  error  String?

  createdAt DateTime @default(now())

  @@index([broadcastId, status])
  @@index([clientId])
}

// ========================================
// УВЕДОМЛЕНИЯ (Dashboard bell + Telegram)
// ========================================

model Notification {
  id String @id @default(cuid())

  type     String // new_booking, cancellation, reschedule, new_review, new_client
  title    String
  message  String
  isRead   Boolean @default(false)
  metadata Json? // { bookingId, clientName, staffName, etc. }

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([businessId, isRead])
  @@index([businessId, createdAt])
}

// ========================================
// SALES BOT — Лиды от бота продаж Staffix
// ========================================

model SalesLead {
  id String @id @default(cuid())

  // Контакты
  telegramId       BigInt?
  telegramUsername String?
  telegramChatId   BigInt? @unique
  instagramId      String? @unique
  fbPsid           String? @unique
  whatsappPhone    String? @unique

  // Профиль
  name         String?
  businessName String?
  businessType String?
  phone        String?
  email        String?

  // Канал
  channel String @default("telegram") // telegram, instagram, whatsapp

  // Воронка
  stage String @default("new") // new, interested, demo_requested, trial_started, converted, lost

  // Контекст
  painPoints      String[] @default([])
  objections      String[] @default([])
  recommendedPlan String?
  notes           String?

  // Онбординг — структурированное состояние шага настройки Staffix
  // 0=not_started, 1=registered, 2=business_profile, 3=telegram_bot,
  // 4=extra_channels, 5=team, 6=catalog, 7=knowledge_base, 8=ai_settings,
  // 9=automations, 10=tested, 11=launched
  onboardingStep  Int?
  onboardingNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // История разговора с ботом Staffix
  history Json @default("[]") // [{role, content}]

  // Follow-up nudges — Виктор автоматически шлёт короткие напоминания
  // тёплым лидам, которые замолчали после его вопроса. Считаем nudge'и
  // чтобы не спамить (лимит 3). См. /api/cron/victor-follow-up.
  lastNudgeAt DateTime?
  nudgeCount  Int       @default(0)

  // Демо-встречи
  demoBookings DemoBooking[]

  @@index([stage])
  @@index([channel])
  @@index([createdAt])
  @@index([nudgeCount, updatedAt])
}

// Записи на демо-встречу (Staffix sales)
model DemoBooking {
  id String @id @default(cuid())

  // Связь с лидом
  salesLeadId String
  salesLead   SalesLead @relation(fields: [salesLeadId], references: [id], onDelete: Cascade)

  // Контакты лида
  contactName     String
  contactPhone    String?
  contactTelegram String?
  contactWhatsapp String?
  businessName    String?
  businessType    String?
  businessAddress String?

  // Расписание
  scheduledAt DateTime // дата и время демо
  duration    Int      @default(60) // минут
  status      String   @default("scheduled") // scheduled, confirmed, completed, cancelled, no_show

  // Заметки
  notes        String?
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scheduledAt])
  @@index([status])
}

// ========================================
// CHANNEL CONVERSATIONS — разговоры через WhatsApp / Facebook
// ========================================

// Диалоги клиентов через WhatsApp и Facebook Messenger (per-business)
model ChannelConversation {
  id         String  @id @default(cuid())
  channel    String // "whatsapp" | "facebook"
  clientId   String // wa_id (phone) или Facebook PSID
  clientName String?

  // История хранится как JSON массив [{role:"user"|"assistant", content:string}]
  history      Json @default("[]")
  messageCount Int  @default(0)

  // AI Memory — summary и метаданные разговора
  summary       String? @db.Text // AI-generated summary каждые 10 сообщений
  topic         String? // booking, inquiry, complaint, feedback, order, other
  outcome       String? // booked, answered, escalated, unresolved, ordered
  needsSummary  Boolean @default(false)
  extractedInfo Json? // { clientNotes: [...], detectedPreferences: [...] }

  // Флаг: база знаний изменилась — обрезать history в следующем ответе бота
  needsContextRefresh Boolean @default(false)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, channel, clientId])
  @@index([businessId, channel])
  @@index([needsSummary])
}

// ========================================
// AI LEARNING — коррекции и инсайты
// ========================================

// Коррекции бота — владелец исправляет ответы, они становятся правилами
model BotCorrection {
  id String @id @default(cuid())

  originalQuestion String @db.Text // вопрос клиента
  wrongAnswer      String @db.Text // неправильный ответ бота
  correctAnswer    String @db.Text // правильный ответ от владельца

  scope      String   @default("global") // global = для всех, client = для конкретного клиента
  keywords   String[] @default([]) // ключевые слова для матчинга
  isActive   Boolean  @default(true)
  usageCount Int      @default(0) // сколько раз применялось

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, isActive])
}

// AI-инсайты — паттерны которые бот обнаружил и предлагает владельцу
model AiInsight {
  id String @id @default(cuid())

  type        String // faq_suggestion, popular_question, client_pattern, improvement
  title       String // краткое описание
  description String @db.Text // подробное описание
  data        Json? // доп данные: { question: "...", frequency: 5 }

  status String @default("new") // new, accepted, dismissed

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, status])
}

// Мета-инсайты для платформы Staffix — daily digest для админа.
// Не привязаны к одному бизнесу: они показывают системные проблемы
// (баги промпта, тренды эскалаций, тарифные алерты, language-issues
// и т.п.). businessId nullable — некоторые типы агрегатные.
model MetaInsight {
  id String @id @default(cuid())

  type        String // stuck_conversation, faq_ignored, dont_know_frequency,
  // quota_pressure, tool_failure, language_gap, system_health
  severity    String @default("info") // info, warn, critical
  title       String
  description String @db.Text
  data        Json? // структурированный контекст: { businessId, count, examples, ... }

  // Опционально привязан к конкретному бизнесу — для drill-down
  businessId String?
  business   Business? @relation("MetaInsightBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  status     String    @default("new") // new, resolved, dismissed
  resolvedAt DateTime?
  resolvedBy String? // email админа
  notes      String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, severity])
  @@index([type, createdAt])
  @@index([businessId])
}

// Sprint 4D (M18) — снимок агрегатов рекламной кампании Meta за день.
// Cron /api/cron/ad-insights читает Marketing API и обновляет upsert'ом
// по (businessId, campaignId, date). Владелец видит на /dashboard/ads
// динамику spend/CPL/CTR и воронку от IG-клика до продажи.
model AdCampaignInsight {
  id String @id @default(cuid())

  businessId String
  business   Business @relation("AdInsightBusiness", fields: [businessId], references: [id], onDelete: Cascade)

  source       String  @default("meta") // meta | tiktok | google — сейчас только meta
  campaignId   String
  campaignName String?

  date        DateTime // день (00:00 UTC) — агрегат Marketing API за сутки
  impressions Int      @default(0)
  clicks      Int      @default(0)
  spend       Float    @default(0) // валюта рекламного кабинета
  currency    String? // USD, EUR, KZT, UZS…

  // Производные (denormalized для скорости чтения)
  ctr Float? // clicks/impressions
  cpl Float? // spend / attributed leads (заполняем cron'ом с воронкой)

  // Атрибуция: сколько лидов и клиентов пришло с рекламы в этот день
  // (мэпим через Lead.channel=instagram|facebook + createdAt для MVP;
  // per-campaign атрибуция — ссылки с utm требуют отдельной инфраструктуры).
  attributedLeads   Int @default(0)
  attributedClients Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, campaignId, date])
  @@index([businessId, date])
}

// ========================================
// OUTREACH CAMPAIGNS — Исходящие кампании
// ========================================

model OutreachCampaign {
  id          String  @id @default(cuid())
  name        String
  description String?
  status      String  @default("active") // active, completed, paused

  leads OutreachLead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OutreachLead {
  id String @id @default(cuid())

  campaignId String
  campaign   OutreachCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // Business info (from CSV)
  businessName String
  category     String?
  city         String?
  website      String?

  // Contact info
  email     String?
  telegram  String?
  instagram String?
  whatsapp  String?

  // Outreach tracking
  outreachChannel String // email | telegram | instagram
  status          String    @default("pending") // pending | sent | replied | registered | paying
  sentAt          DateTime?
  repliedAt       DateTime?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId, status])
  @@index([campaignId, outreachChannel])
}

// ========================================
// РАСПИСАНИЕ МАСТЕРОВ
// ========================================

model StaffSchedule {
  id String @id @default(cuid())

  dayOfWeek Int // 0=Воскресенье, 1=Понедельник ... 6=Суббота
  startTime String // "09:00"
  endTime   String // "18:00"
  isWorkday Boolean @default(true)

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@index([staffId])
}

// Отгулы, отпуска, больничные мастеров
model StaffTimeOff {
  id String @id @default(cuid())

  startDate DateTime // начало (полночь UTC)
  endDate   DateTime // конец включительно (полночь UTC)

  // vacation | sick | personal | other
  reason String  @default("vacation")
  notes  String?

  // owner = владелец добавил | master = мастер сам сообщил
  createdBy String @default("owner")

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([staffId, startDate])
  @@index([staffId, endDate])
}

// ========================================
// ПРОДАЖИ — Товары и Заказы (для магазинов и e-commerce)
// ========================================

// Товары / продукты бизнеса
model Product {
  id String @id @default(cuid())

  name        String
  description String? @db.Text

  price    Int // цена в местной валюте (тиины/копейки/тенге)
  oldPrice Int? // старая цена (для отображения скидки)

  // Наличие
  stock Int? // null = не ограничено; 0 = нет в наличии
  sku   String? // артикул

  // Категоризация
  category String?
  tags     String[] @default([])

  // Медиа
  imageUrl   String?
  productUrl String? // ссылка на товар на сайте магазина

  isActive Boolean @default(true)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockLogs StockLog[]

  @@index([businessId, isActive])
  @@index([businessId, category])
}

// История изменений остатков
model StockLog {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  previousStock Int? // null = was unlimited
  newStock      Int? // null = set to unlimited
  change        Int // delta (positive = added, negative = sold/removed)

  reason  String // "order", "manual", "bulk_update", "import"
  orderId String? // optional: link to order
  note    String? // optional: free-text note

  createdAt DateTime @default(now())

  @@index([productId, createdAt])
}

// Заказы клиентов
model Order {
  id String @id @default(cuid())

  // Человекочитаемый номер: #1001, #1002...
  orderNumber Int

  // Данные клиента (snapshot на момент заказа)
  clientName       String
  clientPhone      String?
  clientAddress    String? // для доставки
  clientTelegramId BigInt?
  clientChannel    String? // telegram | whatsapp | instagram | facebook
  clientChannelId  String? // channel-specific client ID (waId, igScopedId, etc.)
  clientNotes      String? // пожелания клиента

  // Позиции заказа
  items OrderItem[]

  // Финансы
  totalPrice Int // итоговая сумма

  // Статус: new | confirmed | processing | shipped | delivered | cancelled
  status String @default("new")

  // Оплата
  paymentMethod String? // cash | card | online | crypto
  isPaid        Boolean @default(false)

  // Уведомления
  notifiedOwner Boolean @default(false)

  // Привязка к продавцу/менеджеру
  staffId String?
  staff   Staff?  @relation(fields: [staffId], references: [id], onDelete: SetNull)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, orderNumber])
  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([businessId, clientTelegramId])
  @@index([staffId])
}

// Позиции заказа
model OrderItem {
  id String @id @default(cuid())

  // Snapshot данных товара (на случай изменения цены)
  name     String
  price    Int
  quantity Int    @default(1)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

// ========================================
// ПАРТНЁРСКАЯ ПРОГРАММА
// ========================================

// Партнёры (CRM-дистрибьюторы, агентства, рефереры)
model Partner {
  id String @id @default(cuid())

  // Профиль
  name        String
  email       String  @unique
  phone       String?
  company     String? // название компании/агентства
  website     String?
  description String? // как планирует продвигать Staffix

  // Реферальный код (генерируется при одобрении)
  referralCode String? @unique

  // Токен доступа к дашборду (UUID, отправляется на email)
  accessToken String? @unique

  // Статус
  status     String    @default("pending") // pending, approved, rejected, suspended
  approvedAt DateTime?

  // Финансы — Decimal чтобы избежать float drift на агрегации
  commissionRate  Decimal @default(0.20) @db.Decimal(5, 4) // 20% = 0.2000
  totalEarnings   Decimal @default(0) @db.Decimal(12, 2) // суммарно заработано ($)
  totalPaid       Decimal @default(0) @db.Decimal(12, 2) // суммарно выплачено
  pendingPayout   Decimal @default(0) @db.Decimal(12, 2) // ожидает выплаты
  minPayoutAmount Decimal @default(50) @db.Decimal(12, 2) // минимум для выплаты

  // Реквизиты для выплат. Только последние 4 цифры карты — full PAN не хранится
  // (PCI-DSS scope). Полный номер админ вводит руками в банк-клиент.
  cardLast4   String? // 4 цифры
  cardHolder  String? // имя на карте если отличается от name
  bankName    String? // Сбер / Каспи / Тинькофф / Райффайзен / etc.
  payoutNotes String? // заметки от партнёра ("перевод только Каспи Gold", "до 14:00 МСК")

  // Внутренние заметки админа — партнёр их не видит.
  adminNotes String? @db.Text

  // Когда подписано партнёрское соглашение (для бухгалтерии и compliance).
  // null = не подписано, нельзя выплачивать.
  agreementSignedAt DateTime?

  referrals PartnerReferral[]
  earnings  PartnerEarning[]
  payouts   PartnerPayout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([referralCode])
}

// Реферальные переходы (кто пришёл по ссылке партнёра)
model PartnerReferral {
  id String @id @default(cuid())

  // Кто пришёл
  userId    String // User.id кто зарегистрировался
  userEmail String

  // Атрибуция
  referralCode String
  signedUpAt   DateTime @default(now())

  // Конверсия в платящего
  converted     Boolean   @default(false)
  convertedAt   DateTime?
  convertedPlan String? // starter, pro, business, enterprise

  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  earnings PartnerEarning[]

  @@unique([userId])
  @@index([partnerId, converted])
  @@index([referralCode])
}

// Начисления партнёру (за каждый платёж реферала)
model PartnerEarning {
  id String @id @default(cuid())

  // Сумма — Decimal чтобы избежать float drift при агрегации сотен записей
  commissionAmount Decimal @db.Decimal(12, 2) // сколько начислено партнёру ($)
  paymentAmount    Decimal @db.Decimal(12, 2) // полная сумма платежа реферала ($)
  subscriptionPlan String // starter, pro, business, enterprise

  // Статус: pending (в hold-периоде) → available (можно выплатить) → paid (выплачено)
  // cancelled — refund/chargeback клиента, в выплату не идёт
  status String    @default("pending")
  paidAt DateTime?

  // Когда earning становится доступен для выплаты. По умолчанию createdAt + 30 дней
  // (защита от refund/chargeback клиента). Cron каждый день переводит pending → available
  // у тех, у кого availableAt уже прошёл.
  availableAt DateTime?

  // Если cancelled — почему (refund / chargeback / manual)
  cancelledReason String?

  // Привязка к batch-выплате (если уже включён в payout)
  payoutId String?
  payout   PartnerPayout? @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  // PayPro orderId который сгенерировал эту комиссию.
  // Нужен чтобы при ORDER_REFUNDED / ORDER_CHARGED_BACK точно отменить именно
  // тот earning, который относится к возвращённому платежу.
  // @unique — защита от race condition при дублирующихся PayPro webhooks.
  // NULL допускается (legacy/manual earnings) — Postgres трактует множественные
  // NULL как distinct, так что unique их не блокирует.
  payproOrderId String? @unique

  referralId String
  referral   PartnerReferral @relation(fields: [referralId], references: [id], onDelete: Cascade)

  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([partnerId, status])
  @@index([partnerId, createdAt])
  @@index([status, availableAt])
  @@index([payoutId])
}

// Группа выплат партнёру — одна строка = один банковский перевод за период.
// Содержит несколько earning-записей (всё что было available на момент выплаты).
// Создаётся когда админ нажимает «Отметил как выплачено» на странице payouts.
model PartnerPayout {
  id String @id @default(cuid())

  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  // Сколько перевели партнёру одним переводом
  amount Decimal @db.Decimal(12, 2)

  // За какой период (для отчётности — месяц года, например "2026-05")
  periodLabel String?

  // Способ выплаты (всегда "card" в текущей версии — на банковскую карту)
  paymentMethod String @default("card")

  // Reference банковского перевода — для бухгалтерии и доказательства
  // Пример: "TINKOFF-12345-2026-05-05" или просто id транзакции банка
  reference String?

  // Когда фактически был сделан перевод (заполняется админом)
  paidAt DateTime @default(now())

  // Email админа, который провёл выплату — для аудита
  paidByEmail String?

  // Заметки (например "перевод задержался из-за выходных")
  notes String?

  // Снапшот реквизитов на момент выплаты — чтобы потом можно было проверить
  // куда именно перевели, даже если партнёр поменяет реквизиты позже.
  // Только last4 — full PAN не хранится (PCI-DSS).
  recipientCardLast4  String?
  recipientCardHolder String?
  recipientBankName   String?

  earnings PartnerEarning[]

  createdAt DateTime @default(now())

  @@index([partnerId, paidAt])
  @@index([paidAt])
}

// Promo-материалы для всех партнёров: баннеры (картинки) и шаблоны текстов.
// Создаются админом в /admin/partners/assets, видны партнёрам в кабинете.
// Глобальные — не привязаны к конкретному партнёру.
model PartnerAsset {
  id String @id @default(cuid())

  type        String // "banner" | "template"
  title       String
  description String? // подсказка партнёру: куда применить, какая аудитория

  imageUrl String? // для type=banner — ссылка на Vercel Blob
  content  String? @db.Text // для type=template — готовый текст рассылки/поста

  category String? // "social" | "messenger" | "email" | "ads" | "other"
  language String  @default("ru") // ru / en / uz / kz

  sortOrder Int     @default(0) // порядок в кабинете партнёра
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, isActive, sortOrder])
  @@index([language, isActive])
}

// ========================================
// ПРОГРАММА ЛОЯЛЬНОСТИ
// ========================================

model LoyaltyProgram {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  enabled    Boolean  @default(false)
  type       String   @default("cashback") // cashback | visits | tiered
  name       String? // Пользовательское название, напр. "Кэшбэк 5%"

  // Cashback: % от суммы возвращается бонусами
  cashbackPercent Int? @default(5)

  // Visits: каждый N-й визит — награда
  visitsForReward Int?    @default(10)
  rewardType      String? @default("discount") // free | discount
  rewardDiscount  Int?    @default(50) // скидка % для награды

  // Tiered: уровни по сумме покупок
  tiers Json? // [{minSpent:0,name:"Bronze",discount:0},...]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, type]) // один тип программы на бизнес
  @@index([businessId])
}

// Rate limiting — защита от брутфорса
model RateLimitEntry {
  key      String   @id // e.g. "login:192.168.1.1"
  attempts Int      @default(1)
  resetAt  DateTime

  @@map("rate_limit_entries")
}

// ========================================
// CRM ИНТЕГРАЦИИ — передача данных во внешние CRM
// ========================================

model CrmIntegration {
  id String @id @default(cuid())

  // Тип интеграции
  type String // webhook | google_sheets | bitrix24 | amocrm

  // Название (задаёт пользователь)
  name String

  // Конфигурация (зависит от типа):
  // webhook:       { url, secret?, headers? }
  // google_sheets: { spreadsheetId, sheetName, credentialsJson }
  // bitrix24:      { domain, token }
  // amocrm:        { domain, token, pipelineId? }
  config Json

  // Какие события отправлять
  // Варианты: booking_created | booking_confirmed | booking_cancelled |
  //           new_client | review_created | message_received
  events String[] @default([])

  isActive   Boolean   @default(true)
  lastSyncAt DateTime?
  lastError  String? // последняя ошибка отправки

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, isActive])
  @@index([businessId, type])
}

// Webhook deduplication — persistent (replaces in-memory Set)
model WebhookDedup {
  id          String   @id // messageId from Meta/Telegram
  processedAt DateTime @default(now())

  @@index([processedAt])
  @@map("webhook_dedup")
}

// Журнал активности бота для бизнеса. Видит только владелец своего бизнеса
// через /dashboard/activity. Используется для дебага и прозрачности —
// клиент видит ЧТО делал AI-сотрудник, без доступа к Vercel-логам.
//
// Severity:
//   info  — обычные события (получено сообщение, AI ответил, уведомление доставлено)
//   warn  — что-то нештатное но не fatal (fallback на owner вместо staff)
//   error — реальные ошибки (Telegram API упал, БД transaction провалилась)
//
// Type — открытый список строк, не enum — чтобы добавлять новые без миграций:
//   message_received | message_sent | ai_response | tool_called |
//   notification_sent | client_assigned | booking_created | order_created |
//   payment_received | error
//
// summary — короткая человеко-читаемая строка для UI ("Клиент Иван написал «привет»")
// technical — JSON с деталями для разработчика (latency, http_status, errorCode, stack)
//
// Изоляция: API endpoint фильтрует по `businessId = currentUser.business.id`,
// клиент не может увидеть логи чужого бизнеса.
model BusinessActivityLog {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  type     String // см. перечисление в документации модели
  severity String @default("info") // info | warn | error

  summary   String @db.Text
  technical Json? // {chatId, model, tokens, latency, errorCode, stack, ...}

  // Опциональные привязки к сущностям — для UI-линков «открыть клиента / staff»
  channel  String? // telegram | whatsapp | instagram | facebook
  clientId String? // ID клиента (Client.id) если применимо
  staffId  String? // ID сотрудника если применимо

  createdAt DateTime @default(now())

  @@index([businessId, createdAt(sort: Desc)])
  @@index([businessId, type, createdAt(sort: Desc)])
  @@index([businessId, severity, createdAt(sort: Desc)])
}
